#!/bin/sh
set -eu

usage() {
  echo "Usage: $0 <binary>" >&2
  exit 2
}

test $# -eq 1 || usage

binary=$1

if [ ! -x "$binary" ]; then
  echo "Release smoke failed: executable not found: $binary" >&2
  exit 1
fi

workdir=${TMPDIR:-/tmp}/aria2-release-smoke.$$
mkdir -p "$workdir"

server_pid=
cleanup() {
  if [ -n "$server_pid" ]; then
    kill "$server_pid" 2>/dev/null || true
  fi
  rm -rf "$workdir"
}
trap cleanup EXIT HUP INT TERM

printf 'aria2-next release smoke\n' > "$workdir/release-smoke.txt"

cd "$workdir"
python3 -m http.server 18080 --bind 127.0.0.1 &
server_pid=$!
sleep 1

"$binary" --version > version.txt

"$binary" \
  --dir=release-smoke-out \
  --out=release-smoke.txt \
  --allow-overwrite=true \
  http://127.0.0.1:18080/release-smoke.txt

test "$(cat release-smoke-out/release-smoke.txt)" = "aria2-next release smoke"

"$binary" \
  --dir=release-smoke-hostname-out \
  --out=release-smoke.txt \
  --allow-overwrite=true \
  http://localhost:18080/release-smoke.txt

test "$(cat release-smoke-hostname-out/release-smoke.txt)" = "aria2-next release smoke"
