# Maintained dependency baseline for aria2-next release packaging.
# Keep this file as the authoritative version source for packaging scripts,
# Dockerfiles, release workflows, and release documentation.

ZLIB_VERSION=1.3.2
ZLIB_ARCHIVE=zlib-${ZLIB_VERSION}.tar.gz
ZLIB_URL=https://github.com/madler/zlib/releases/download/v${ZLIB_VERSION}/${ZLIB_ARCHIVE}

EXPAT_VERSION=2.8.1
EXPAT_TAG=R_2_8_1
EXPAT_ARCHIVE=expat-${EXPAT_VERSION}.tar.bz2
EXPAT_URL=https://github.com/libexpat/libexpat/releases/download/${EXPAT_TAG}/${EXPAT_ARCHIVE}

SQLITE_AUTOCONF_VERSION=3530100
SQLITE_VERSION=3.53.1
SQLITE_YEAR=2026
SQLITE_ARCHIVE=sqlite-autoconf-${SQLITE_AUTOCONF_VERSION}.tar.gz
SQLITE_URL=https://www.sqlite.org/${SQLITE_YEAR}/${SQLITE_ARCHIVE}

CARES_VERSION=1.34.6
CARES_TAG=cares-1_34_6
CARES_ARCHIVE=c-ares-${CARES_VERSION}.tar.gz
CARES_URL=https://github.com/c-ares/c-ares/releases/download/${CARES_TAG}/${CARES_ARCHIVE}

LIBSSH2_VERSION=1.11.1
LIBSSH2_ARCHIVE=libssh2-${LIBSSH2_VERSION}.tar.bz2
LIBSSH2_URL=https://github.com/libssh2/libssh2/releases/download/libssh2-${LIBSSH2_VERSION}/${LIBSSH2_ARCHIVE}

OPENSSL_VERSION=3.5.6
OPENSSL_SERIES=3.5
OPENSSL_ARCHIVE=openssl-${OPENSSL_VERSION}.tar.gz
OPENSSL_URL=https://github.com/openssl/openssl/releases/download/openssl-${OPENSSL_VERSION}/${OPENSSL_ARCHIVE}

GMP_VERSION=6.3.0
GMP_ARCHIVE=gmp-${GMP_VERSION}.tar.xz
GMP_URL=https://ftpmirror.gnu.org/gmp/${GMP_ARCHIVE}

LIBGPG_ERROR_VERSION=1.61
LIBGPG_ERROR_ARCHIVE=libgpg-error-${LIBGPG_ERROR_VERSION}.tar.bz2
LIBGPG_ERROR_URL=https://www.gnupg.org/ftp/gcrypt/libgpg-error/${LIBGPG_ERROR_ARCHIVE}

LIBGCRYPT_VERSION=1.12.2
LIBGCRYPT_ARCHIVE=libgcrypt-${LIBGCRYPT_VERSION}.tar.bz2
LIBGCRYPT_URL=https://www.gnupg.org/ftp/gcrypt/libgcrypt/${LIBGCRYPT_ARCHIVE}

ANDROID_NDK_VERSION=r29
