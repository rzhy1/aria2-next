{
    local cur prev split=false
    COMPREPLY=()
    COMP_WORDBREAKS=${COMP_WORDBREAKS//=}

    cmd=${COMP_WORDS[0]}
    _get_comp_words_by_ref cur prev
    case $prev in
        --ftp-type)
            COMPREPLY=( $( compgen -W 'binary ascii' -- "$cur" ) )
            return 0
            ;;
        --proxy-method)
            COMPREPLY=( $( compgen -W 'get tunnel' -- "$cur" ) )
            return 0
            ;;
        --file-allocation)
            COMPREPLY=( $( compgen -W 'none prealloc trunc falloc' -- "$cur" ) )
            return 0
            ;;
        --log-level|--terminal-log-level|--file-log-level)
            COMPREPLY=( $( compgen -W 'trace debug info warn error critical off' -- "$cur" ) )
            return 0
            ;;
        --event-poll)
            COMPREPLY=( $( compgen -W 'kqueue poll select' -- "$cur" ) )
            return 0
            ;;
        --stream-piece-selector)
            COMPREPLY=( $( compgen -W 'default inorder random geom' -- "$cur" ) )
            return 0
            ;;
        --download-result)
            COMPREPLY=( $( compgen -W 'default full hide' -- "$cur" ) )
            return 0
            ;;
        --min-tls-version)
            COMPREPLY=( $( compgen -W 'TLSv1.1 TLSv1.2 TLSv1.3' -- "$cur" ) )
            return 0
            ;;
        --dir)
            _filedir -d
            return 0
            ;;
        --torrent-file)
            _filedir '@(torrent)'
            return 0
            ;;
        --torrent-metadata)
            COMPREPLY=( $( compgen -W 'save start memory' -- "$cur" ) )
            return 0
            ;;
    esac
    case $cur in
        -*)
            COMPREPLY=( $( compgen -W '--version --help --help=#basic --help=#advanced --help=#http --help=#https --help=#ftp --help=#bittorrent --help=#ed2k --help=#cookie --help=#hook --help=#file --help=#rpc --help=#checksum --help=#experimental --help=#deprecated --help=#help --help=#all --timeout --connect-timeout --max-tries --auto-save-interval --log-file --log-file=auto --log-file=off --dir --out --split --daemon --daemon=false --referer --lowest-speed-limit --piece-length --max-overall-download-limit --max-download-limit --file-allocation --no-file-allocation-limit --allow-overwrite --allow-overwrite=false --realtime-chunk-checksum --realtime-chunk-checksum=false --check-integrity --check-integrity=false --netrc-path --continue --continue=false --no-netrc --no-netrc=false --input-file --deferred-input --deferred-input=false --max-concurrent-downloads --force-sequential --force-sequential=false --auto-file-renaming --auto-file-renaming=false --parameterized-uri --parameterized-uri=false --allow-piece-length-change --allow-piece-length-change=false --no-conf --no-conf=false --conf-path --stop --quiet --quiet=false --summary-interval --log-level --terminal-log-level --file-log-level --log-max-size --log-max-files --remote-time --remote-time=false --max-file-not-found --event-poll --enable-rpc --enable-rpc=false --rpc-listen-port --rpc-max-request-size --rpc-listen-all --rpc-listen-all=false --rpc-allow-origin-all --rpc-allow-origin-all=false --rpc-save-upload-metadata --rpc-save-upload-metadata=false --dry-run --dry-run=false --on-download-start --on-download-pause --on-download-stop --on-download-complete --on-download-error --interface --multiple-interface --disable-ipv6 --disable-ipv6=false --human-readable --human-readable=false --remove-control-file --remove-control-file=false --always-resume --always-resume=false --max-resume-failure-tries --save-session --max-connection-per-server --min-split-size --conditional-get --conditional-get=false --max-download